@page "/settings"
@using Sofragrancia.UI.Components

<Topbar Title="⚙️ Configurações" Breadcrumb="Início > Configurações" />

<div class="page-content" style="padding: 20px;">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="card-title text-primary mb-4">Perfil do Usuário</h5>
            <p class="text-muted">Página em construção. Em breve você poderá editar suas preferências aqui.</p>
            
            <div class="mt-4">
                <button class="btn btn-outline-secondary" disabled>Editar Perfil</button>
                <button class="btn btn-outline-danger" disabled>Alterar Senha</button>
            </div>
        </div>
    </div>
</div>