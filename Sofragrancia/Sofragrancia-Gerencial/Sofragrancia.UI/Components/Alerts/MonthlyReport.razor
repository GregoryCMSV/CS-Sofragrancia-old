<div class="table-card">
    <div class="table-header" style="margin-bottom:20px;">
        <div>
            <div class="chart-title">📊 Relatório Customizado</div>
            <div class="chart-subtitle" style="margin-bottom: 0;">Configure o período livre e as seções dos dados que deseja exportar</div>
        </div>
        <div style="display:flex; gap:10px;">
            <button class="btn btn-primary" @onclick="EnviarTesteRelatorio">📤 Enviar Teste</button>
        </div>
    </div>

    <div style="margin-bottom:25px;">
        <div style="padding:16px; background:#fafafa; border-radius:10px; border:1px solid #eee;">
            <div style="font-size:14px; font-weight:700; color:#1a1a2e; margin-bottom:12px;">📅 Período de Coleta dos Dados</div>
            
            <div class="row g-3">
                <div class="col-md-3">
                    <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:6px;">DATA INICIAL</label>
                    <input type="date" class="filter-input" style="width:100%;" 
                           @bind-value="Config.DataInicialRelatorio" @bind-value:event="onchange" />
                </div>
                
                <div class="col-md-3">
                    <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:6px;">DATA FINAL</label>
                    <input type="date" class="filter-input" style="width:100%;" 
                           @bind-value="Config.DataFinalRelatorio" @bind-value:event="onchange" />
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2" style="margin-bottom: 25px;">
        @foreach (var item in SecoesRelatorio)
        {
            <div class="col">
                <label style="display:flex; align-items:center; gap:8px; padding:12px;
                            background:#f8f9ff; border-radius:8px; border:1px solid #ddd;
                            font-size:13px; width: 100%; cursor: pointer;">

                    <input type="checkbox" @bind="item.Ativo" style="width:16px; height:16px;" />
                    <span>@item.Icone @item.Titulo</span>
                </label>
            </div>
        }
    </div>
