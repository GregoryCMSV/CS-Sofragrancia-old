<div class="table-card">
    <div class="table-header" style="margin-bottom:20px;">
        <div>
            <div class="chart-title">📊 Relatório Mensal Automático</div>
            <div class="chart-subtitle" style="margin-bottom: 0;">Configure o relatório completo que será enviado no fechamento de cada mês</div>
        </div>
        <div style="display:flex; gap:10px;">
            <button class="btn btn-outline" @onclick="VisualizarPreviewRelatorio">👁️ Preview</button>
            <button class="btn btn-primary" @onclick="EnviarTesteRelatorio">📤 Enviar Teste</button>
        </div>
    </div>

    <div style="margin-bottom:25px;">
        <div style="font-size:14px; font-weight:700; color:#1a1a2e; margin-bottom:12px;">📅 Agendamento do Envio</div>
        <div class="row g-3">
            <div class="col-md-6" @onclick='() => Config.AgendamentoRelatorio = "UltimoDiaUtil"' style="cursor: pointer;">
                <div style="padding: 15px; border: 1px solid @(Config.AgendamentoRelatorio == "UltimoDiaUtil" ? "#3498db" : "#eee"); 
                            background: @(Config.AgendamentoRelatorio == "UltimoDiaUtil" ? "#f8f9ff" : "#fff"); 
                            opacity: @(Config.AgendamentoRelatorio == "UltimoDiaUtil" ? "1" : "0.6"); 
                            border-radius: 8px; transition: all 0.2s ease;">
                    <div style="font-weight: bold; font-size: 14px; color: @(Config.AgendamentoRelatorio == "UltimoDiaUtil" ? "#1a1a2e" : "#555");">
                        📅 Último dia útil do mês
                    </div>
                    <div class="text-muted small" style="margin-top: 4px;">Enviado automaticamente no fechamento — ideal para revisão antes do próximo ciclo.</div>
                </div>
            </div>
            
            <div class="col-md-6" @onclick='() => Config.AgendamentoRelatorio = "DiaPrimeiro"' style="cursor: pointer;">
                <div style="padding: 15px; border: 1px solid @(Config.AgendamentoRelatorio == "DiaPrimeiro" ? "#3498db" : "#eee"); 
                            background: @(Config.AgendamentoRelatorio == "DiaPrimeiro" ? "#f8f9ff" : "#fff"); 
                            opacity: @(Config.AgendamentoRelatorio == "DiaPrimeiro" ? "1" : "0.6"); 
                            border-radius: 8px; transition: all 0.2s ease;">
                    <div style="font-weight: bold; font-size: 14px; color: @(Config.AgendamentoRelatorio == "DiaPrimeiro" ? "#1a1a2e" : "#555");">
                        🌅 Dia 1 do mês seguinte
                    </div>
                    <div class="text-muted small" style="margin-top: 4px;">Com dados consolidados do mês anterior — ideal para reuniões de planejamento.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2" style="margin-bottom: 25px;">
        @foreach (var item in SecoesRelatorio)
        {
            <div class="col">
                <label style="display:flex; align-items:center; gap:8px; padding:12px;
                            background:#f8f9ff; border-radius:8px; border:1px solid #ddd;
                            font-size:13px; width: 100%;">

                    <input type="checkbox" @bind="item.Ativo"
                        style="width:16px; height:16px;" />
                    <span>@item.Icone @item.Titulo</span>
                </label>
            </div>
        }
    </div>

    <div style="font-size:14px; font-weight:700; color:#1a1a2e; margin-bottom:12px;">👁️ Preview do Relatório — Março/2026</div>
    <div style="background: #fff; border: 1px solid #ddd; padding: 30px; border-radius: 8px; max-width: 700px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
        <div style="text-align:center; margin-bottom:20px;">
            <div style="font-size:22px; font-weight:800; color:#1a1a2e; letter-spacing: 1px;">🌸 SOFRAGRÂNCIA</div>
            <div style="font-size:14px; color:#888; margin-top:4px;">Relatório Gerencial Mensal — Março/2026</div>
            <div style="font-size:11px; color:#aaa; margin-top:4px;">Gerado automaticamente em 31/03/2026 às 23:59 | Enviado para @Config.EmailDestinatario</div>
        </div>
        
        <div style="width:100%; height:3px; background:linear-gradient(90deg,#e6a817,#3498db); border-radius:2px; margin-bottom:20px;"></div>
        
        <div class="row g-2 text-center" style="margin-bottom: 20px;">
            <div class="col-3"><div style="background: #f8f9fa; padding: 10px; border-radius: 6px;"><div style="font-size: 11px; color: #888;">Fat. Bruto</div><div style="font-size: 16px; font-weight: 700; color:#3498db;">R$ 285k</div></div></div>
            <div class="col-3"><div style="background: #f8f9fa; padding: 10px; border-radius: 6px;"><div style="font-size: 11px; color: #888;">Fat. Líquido</div><div style="font-size: 16px; font-weight: 700; color:#2ecc71;">R$ 251k</div></div></div>
            <div class="col-3"><div style="background: #f8f9fa; padding: 10px; border-radius: 6px;"><div style="font-size: 11px; color: #888;">Meta</div><div style="font-size: 16px; font-weight: 700; color:#e6a817;">110,7%</div></div></div>
            <div class="col-3"><div style="background: #f8f9fa; padding: 10px; border-radius: 6px;"><div style="font-size: 11px; color: #888;">Cancelados</div><div style="font-size: 16px; font-weight: 700; color:#e74c3c;">8</div></div></div>
        </div>
        
        <div style="margin-top:15px; font-size:12px; color:#555; line-height: 1.8;">
            <strong>📌 Destaques do Mês:</strong><br>
            ✅ Meta atingida em 110,7%<br>
            ✅ BENJAMIN FRANKLIN e INACIO DE LOYOLA acima de 99% da cota<br>
            ⚠️ 8 cancelamentos — 45% por problemas de crédito<br>
            🔴 CINDY CRAWFORD com 35,4% de cota e 9,3% de desconto médio<br>
            💹 SOXERO masc./fem. sem reajuste há 6 meses — defasagem de 4,8%<br><br>
            <strong>🔮 Projeção Abril/2026:</strong> Manter ritmo sugere faturamento de R$ 298k (+4,4%).
        </div>
    </div>
</div>