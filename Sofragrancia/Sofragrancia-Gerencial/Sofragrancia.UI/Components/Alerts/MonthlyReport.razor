<div class="table-card" style="margin-bottom: 20px;">
    <div class="table-header" style="margin-bottom: 20px;">
        <div>
            <div class="chart-title">📊 Relatório Customizado</div>
            <div class="chart-subtitle" style="margin-bottom: 0;">Configure o período livre e as seções dos dados que deseja exportar</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div style="display:flex; align-items:center; gap:12px; padding:16px; background:#e8f8f5; border-radius:10px; border:1px solid #1abc9c; height: 100%;">
                <span style="font-size:28px;">📨</span>
                <div style="flex:1">
                    <div style="font-size:13px; font-weight:700; color:#1a1a2e;">E-mail do Destinatário</div>
                    <input type="email" class="filter-input" style="margin-top:6px; width:100%;" placeholder="destinatario.externo@email.com" @bind-value="Model.EmailDestinatario" />
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div style="padding:16px; background:#fafafa; border-radius:10px; border:1px solid #eee; height: 100%;">
                <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:10px;">📅 Período de Coleta dos Dados</div>
                <div class="row g-2">
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:4px;">DATA INICIAL</label>
                        <input type="date" class="filter-input" style="width:100%;" @bind-value="Model.DataInicialRelatorio"/>
                    </div>
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:4px;">DATA FINAL</label>
                        <input type="date" class="filter-input" style="width:100%;" @bind-value="Model.DataFinalRelatorio"/>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:12px;">🗂️ Selecione as Seções do Relatório</div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2" style="margin-bottom: 25px;">
        @foreach (var item in Model.Sections)
        {
            <div class="col">
                <label style="display:flex; align-items:center; gap:8px; padding:12px;
                            background:#f8f9ff; border-radius:8px; border:1px solid #ddd;
                            font-size:13px; width: 100%; cursor: pointer; transition: opacity 0.2s;
                            opacity: @(item.Ativo ? "1" : "0.55");">

                    <input type="checkbox" style="width:16px; height:16px; cursor: pointer;" @bind="item.Ativo" />
                    <span class="fw-medium" style="color: #2c3e50;">@item.Icone @item.Titulo</span>
                </label>
            </div>
        }
    </div>

    <div class="d-flex justify-content-end align-items-center gap-2 pt-3" style="border-top: 1px solid #eee;">
        <button class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 8px; font-size: 14px;" @onclick="EnviarRelatorioCustomizado">
            📤 Enviar Relatório Customizado
        </button>
    </div>
</div>