<div class="table-card" style="margin-bottom: 20px;">
    <div class="table-header" style="margin-bottom: 20px;">
        <div>
            <div class="chart-title">📱 Canais de Notificação</div>
            <div class="chart-subtitle" style="margin-bottom: 0;">Configure onde você quer receber os alertas</div>
        </div>
        <button class="btn btn-success" @onclick="SalvarConfiguracoes">
            💾 Salvar Configurações
        </button>
    </div>
    
    <div class="row g-3">
        <div class="col-md-6">
            <div style="display:flex; align-items:center; gap:12px; padding:16px; background:#d6eaf8; border-radius:10px; border:1px solid #2980b9;">
                <span style="font-size:28px;">📧</span>
                <div style="flex:1">
                    <div style="font-size:13px; font-weight:700; color:#1a1a2e;">E-mail</div>
                    <input type="email" class="filter-input" style="margin-top:6px; width:100%;" placeholder="gerente@sofragrancia.com.br" @bind-value="Config.EmailDestinatario" />
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" style="cursor: pointer; width: 40px; height: 20px;" @bind="Config.EmailAtivo">
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div style="padding:16px; background:#fafafa; border-radius:10px; border:1px solid #eee; height: 100%;">
                <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:10px;">⏰ Horário e Frequência de Envio</div>
                <div class="row g-2">
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:4px;">HORA PREFERIDA</label>
                        <input type="time" class="filter-input" style="width:100%;" @bind-value="Config.HorarioEnvio" />
                    </div>
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:8px;">
                            DIAS PARA RECEBIMENTO DO RELATÓRIO
                        </label>
                        <div class="days-checkbox-container">
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoSegunda" />
                                <span>S</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoTerca" />
                                <span>T</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoQuarta" />
                                <span>Q</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoQuinta" />
                                <span>Q</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoSexta" />
                                <span>S</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoSabado" />
                                <span>S</span>
                            </label>
                            <label class="day-checkbox-label">
                                <input type="checkbox" @bind="Config.FaturamentoDomingo" />
                                <span>D</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="table-card" style="margin-bottom: 25px;">
    <div class="table-header">
        <div>
            <div class="chart-title">⚙️ Configuração de Indicadores</div>
            <div class="chart-subtitle">Defina limites para cada alerta</div>
        </div>
    </div>
    
    <div style="width: 100%; overflow-x: auto;">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th style="width: 50%;">Indicador</th>
                    <th style="width: 35%;">Limite / Gatilho</th>
                    <th style="width: 15%; text-align: center;">Ativo</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in AlertConfigs)
            {
                <tr>
                    <td>
                        <div class="fw-bold" style="color: #1a1a2e;">@item.Title</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <span class="text-muted" style="font-size:12px;">@item.Operator</span>

                            <input type="number"
                                class="filter-input"
                                style="width: 80px; text-align: center;"
                                @bind="item.Value" />
                            <span class="text-muted" style="font-size:12px;">@item.Unit</span>
                        </div>
                    </td>
                    <td class="text-center">
                        <div class="form-check form-switch d-inline-block">
                            <input class="form-check-input"
                                type="checkbox"
                                @bind="item.IsActive" />
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

