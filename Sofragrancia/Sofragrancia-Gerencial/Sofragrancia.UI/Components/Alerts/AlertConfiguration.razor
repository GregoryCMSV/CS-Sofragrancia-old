<div class="table-card" style="margin-bottom: 20px;">
    <div class="table-header" style="margin-bottom: 20px;">
        <div>
            <div class="chart-title">📱 Canais de Notificação</div>
            <div class="chart-subtitle" style="margin-bottom: 0;">Configure onde você quer receber os alertas</div>
        </div>
    </div>
    
    <div class="row g-3 mb-4"> 
        <div class="col-md-6">
            <div style="display:flex; align-items:center; gap:12px; padding:16px; background:#d6eaf8; border-radius:10px; border:1px solid #2980b9;">
                <span style="font-size:28px;">📧</span>
                <div style="flex:1">
                    <div style="font-size:13px; font-weight:700; color:#1a1a2e;">E-mail</div>
                    <input type="email" class="filter-input" style="margin-top:6px; width:100%;" placeholder="gerente@sofragrancia.com.br" @bind-value="Model.EmailDestinatario" />
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" style="cursor: pointer; width: 40px; height: 20px;" @bind="Model.EmailAtivo">
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div style="padding:16px; background:#fafafa; border-radius:10px; border:1px solid #eee; height: 100%;">
                <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:10px;">⏰ Horário e Frequência de Envio</div>
                <div class="row g-2">
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:4px;">HORA PREFERIDA</label>
                        <input type="time" class="filter-input" style="width:100%;" @bind-value="Model.HorarioEnvio" />
                    </div>
                    <div class="col-6">
                        <label style="font-size:11px; color:#888; font-weight:600; display:block; margin-bottom:8px;">
                            DIAS PARA RECEBIMENTO DO RELATÓRIO
                        </label>
                        <div class="days-checkbox-container">
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoSegunda" /><span>S</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoTerca" /><span>T</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoQuarta" /><span>Q</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoQuinta" /><span>Q</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoSexta" /><span>S</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoSabado" /><span>S</span></label>
                            <label class="day-checkbox-label"><input type="checkbox" @bind="Model.FaturamentoDomingo" /><span>D</span></label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-header">
        <div>
            <div class="chart-title">⚙️ Configuração de Indicadores</div>
            <div class="chart-subtitle">Defina limites para cada alerta</div>
        </div>
    </div>
    
    <div style="width: 100%; overflow-x: auto; margin-bottom: 24px;"> 
        <table class="table table-hover align-middle m-0" style="border-collapse: separate; border-spacing: 0;"> 
            <thead>
                <tr>
                    <th style="width: 40%; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #7f8c8d; border-bottom: 2px solid #edf2f7; padding: 10px 16px;">Indicador</th>
                    <th style="width: 35%; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #7f8c8d; border-bottom: 2px solid #edf2f7; padding: 10px 16px;">Condição / Operador</th>
                    <th style="width: 15%; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #7f8c8d; border-bottom: 2px solid #edf2f7; padding: 10px 16px;">Valor Limite</th>
                    <th style="width: 10%; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #7f8c8d; border-bottom: 2px solid #edf2f7; padding: 10px 16px; text-align: center;">Ativo</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Indicators)
            {
                <tr style="opacity: @(item.IsActive ? "1" : "0.45"); transition: all 0.2s ease-in-out;">
                    <td style="padding: 12px 16px; border-bottom: 1px solid #edf2f7;">
                        <div class="fw-semibold" style="color: #2c3e50; font-size: 13px;">@item.Title</div>
                    </td>
                    
                    <td style="padding: 12px 16px; border-bottom: 1px solid #edf2f7;">
                        @if (item.OperadoresPermitidos.Count > 1)
                        {
                            // 🔓 Se houver mais de uma opção, vira um Select ativo
                            <select class="form-select form-select-sm" style="cursor: pointer; border-radius: 6px; border-color: #cbd5e1; color: #4a5568; font-size: 12px; padding: 4px 8px; max-width: 180px;" @bind="item.Operator">
                                @foreach (var op in item.OperadoresPermitidos)
                                {
                                    <option value="@op">@(OperadoresDisponiveis.ContainsKey(op) ? OperadoresDisponiveis[op] : op)</option>
                                }
                            </select>
                        }
                        else
                        {
                            // 🔒 Se houver só uma opção, exibe como texto fixo elegante
                            <span class="badge bg-light text-secondary border px-2 py-1" style="font-size: 12px; font-weight: 500;">
                                @(OperadoresDisponiveis.ContainsKey(item.Operator) ? OperadoresDisponiveis[item.Operator] : item.Operator)
                            </span>
                        }
                    </td>
                    
                    <td style="padding: 12px 16px; border-bottom: 1px solid #edf2f7;">
                        <div class="d-flex align-items-center gap-2">
                            <input type="number" class="form-control form-control-sm text-center" style="max-width: 70px; height: 28px; font-size: 12px; font-weight: 500; color: #2d3748; border-radius: 6px; border-color: #cbd5e1; padding: 2px 6px;" @bind="item.Value" />
                            
                            @if (item.UnidadesPermitidas.Count > 1)
                            {
                                // 🔓 Nova funcionalidade: Unidade vira um select se houver mais de uma opção (ex: dias/meses)
                                <select class="form-select form-select-sm" style="cursor: pointer; border-radius: 6px; border-color: #cbd5e1; color: #4a5568; font-size: 12px; padding: 2px 4px; max-width: 90px; height: 28px;" @bind="item.Unit">
                                    @foreach (var uni in item.UnidadesPermitidas)
                                    {
                                        <option value="@uni">@uni</option>
                                    }
                                </select>
                            }
                            else
                            {
                                // 🔒 Unidade fica fixa se só houver uma cadastrada no banco
                                <span style="font-size: 12px; color: #94a3b8; font-weight: 500; user-select: none;">
                                    @item.Unit
                                </span>
                            }
                        </div>
                    </td>
                    
                    <td class="text-center" style="padding: 12px 16px; border-bottom: 1px solid #edf2f7;">
                        <div class="form-check form-switch d-inline-block">
                            <input class="form-check-input" type="checkbox" style="cursor: pointer; transform: scale(1.05);" @bind="item.IsActive" />
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-end align-items-center gap-2 pt-3" style="border-top: 1px solid #eee;">
        <button class="btn btn-success px-4 py-2 fw-bold" style="border-radius: 8px; font-size: 14px;" @onclick="SalvarConfiguracoes">
            💾 Salvar Configurações
        </button>
    </div>
</div>